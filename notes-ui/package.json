{
  "name": "notes-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean:dist": "del-cli ./dist/**",
    "clean:www": "del-cli --force ../assets/www",
    "copy:dist": "ncp ./dist ../assets/www",
    "build": "rspack build --mode production",
    "dev": "rspack build --mode development --watch",
    "release": "npm run clean:dist && npm run build && npm run clean:www && npm run copy:dist",
    "tsc": "tsc --noEmit",
    "lint": "npx eslint ./src && npm run prettier",
    "lint:fix": "npx eslint --fix ./src && npm run prettier:fix",
    "prettier": "npx prettier --check ./src",
    "prettier:fix": "npx prettier --write ./src"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@gravity-ui/eslint-config": "^4.3.1",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "ncp": "^2.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "typescript": "$typescript"
  }
}
